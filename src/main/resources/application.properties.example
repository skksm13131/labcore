spring.application.name=LabCore

spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=${LABCORE_DB_URL:jdbc:mysql://localhost:3306/labcore?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true}
spring.datasource.username=${LABCORE_DB_USERNAME:root}
spring.datasource.password=${LABCORE_DB_PASSWORD:123456}

mybatis-plus.configuration.map-underscore-to-camel-case=true
mybatis-plus.global-config.db-config.id-type=auto

logging.file.name=${LABCORE_LOG_FILE:logs/labcore.log}
logging.level.com.hwz=${LABCORE_LOG_LEVEL:INFO}

server.address=${LABCORE_SERVER_ADDRESS:0.0.0.0}
labcore.cors.allowed-origins=${LABCORE_CORS_ALLOWED_ORIGINS:https://labcore.henu.edu.cn,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080}
labcore.learning.template-storage-dir=${LABCORE_TEMPLATE_STORAGE_DIR:data/learning-templates}
labcore.assignment.upload-dir=${LABCORE_ASSIGNMENT_UPLOAD_DIR:data/assignment-submissions}
labcore.assignment.material-dir=${LABCORE_ASSIGNMENT_MATERIAL_DIR:data/assignment-materials}
labcore.assignment.batch-download-max-bytes=${LABCORE_ASSIGNMENT_BATCH_DOWNLOAD_MAX_BYTES:21474836480}
labcore.assignment.max-files-per-submission=${LABCORE_ASSIGNMENT_MAX_FILES_PER_SUBMISSION:5}
labcore.assignment.max-bytes-per-submission=${LABCORE_ASSIGNMENT_MAX_BYTES_PER_SUBMISSION:1073741824}
spring.servlet.multipart.max-file-size=${LABCORE_MULTIPART_MAX_FILE_SIZE:300MB}
spring.servlet.multipart.max-request-size=${LABCORE_MULTIPART_MAX_REQUEST_SIZE:330MB}
labcore.auth.access-token-secret=${LABCORE_TOKEN_SECRET:CHANGE_ME_TO_A_LONG_RANDOM_SECRET}
labcore.auth.access-token-ttl-seconds=${LABCORE_ACCESS_TOKEN_TTL_SECONDS:7200}
labcore.admin.default-password=${LABCORE_ADMIN_DEFAULT_PASSWORD:Admin@12345678}
spring.jackson.deserialization.fail-on-unknown-properties=false
server.error.include-stacktrace=never
server.error.include-message=never
