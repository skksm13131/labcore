spring.application.name=LabCore

spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://localhost:3306/labcore?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
spring.datasource.username=CHANGE_ME
spring.datasource.password=CHANGE_ME

mybatis-plus.configuration.map-underscore-to-camel-case=true
mybatis-plus.global-config.db-config.id-type=auto

logging.file.name=logs/labcore.log
logging.level.com.hwz=INFO

server.address=0.0.0.0
labcore.learning.template-storage-dir=data/learning-templates
labcore.assignment.upload-dir=data/assignment-submissions
labcore.assignment.material-dir=data/assignment-materials
spring.servlet.multipart.max-file-size=300MB
spring.servlet.multipart.max-request-size=330MB
labcore.auth.access-token-secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
labcore.auth.access-token-ttl-seconds=7200
labcore.admin.default-password=Admin@12345678
spring.jackson.deserialization.fail-on-unknown-properties=false
server.error.include-stacktrace=never
server.error.include-message=never
